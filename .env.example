# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-supabase-url.com
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# S3 (IDCloudhost) - Optional
EXPO_PUBLIC_S3_BUCKET=pjm-mobile-storage
EXPO_PUBLIC_S3_REGION=sgp1
EXPO_PUBLIC_S3_ENDPOINT=https://is3.cloudhost.id
EXPO_PUBLIC_S3_ACCESS_KEY=your-access-key
EXPO_PUBLIC_S3_SECRET_KEY=your-secret-key

# App Config
EXPO_PUBLIC_APP_NAME=BengkelLas
EXPO_PUBLIC_DATE_FORMAT=DD-MM-YYYY
EXPO_PUBLIC_CURRENCY=IDR
